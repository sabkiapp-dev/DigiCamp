[Unit]
Description=DigiCamp Frontend (Flutter Web Interface)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/DigiCamp/digicamp_interface
ExecStart=/usr/bin/python3 /opt/DigiCamp/digicamp/services/server.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
